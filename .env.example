# Server
PORT=3000
NODE_ENV=local

# MongoDB
MONGODB_URI=mongodb://localhost:27017/my-app

# JWT
JWT_SECRET=your-jwt-secret-here

# Logging
LOG_LEVEL=debug

# Redis (for Bull job queues)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# AWS (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# App URL
APP_URL=http://localhost:3000
